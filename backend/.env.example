# ── Demo / local mode ──────────────────────────────────────────────
# Set USE_LOCAL_DB=true to skip Azure and store records in local_db.json
USE_LOCAL_DB=true

# ── PINs ───────────────────────────────────────────────────────────
OPERATIVE_PIN=1234
MANAGER_PIN=5678

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret

# ── Azure Cosmos DB (only needed when USE_LOCAL_DB=false) ──────────
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=your-cosmos-key
# COSMOS_DATABASE=cpu_db
# COSMOS_CONTAINER=records

# ── Demo / local mode ──────────────────────────────────────────────
# Set USE_LOCAL_DB=true to skip Azure and store records in local_db.json
USE_LOCAL_DB=true

# ── PINs ───────────────────────────────────────────────────────────
OPERATIVE_PIN=1234
MANAGER_PIN=5678

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret

# ── Azure Cosmos DB (only needed when USE_LOCAL_DB=false) ──────────
# Connection string (preferred — find it in Azure Portal → Cosmos DB → Keys)
# COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=...
# COSMOS_DB_NAME=cpu_db
# COSMOS_CONTAINER_NAME=records
#
# Endpoint + key (fallback if COSMOS_CONNECTION_STRING is not set)
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=your-cosmos-key

# ── CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to * (local dev only).
# CORS_ORIGINS=https://your-app.azurestaticapps.net,https://localhost:5173
